# Forensic Report Writer - Environment Configuration
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control

# Flask Configuration
FLASK_ENV=production
FLASK_DEBUG=False

# Database Configuration
DATABASE_URL=sqlite:///server.db
# For PostgreSQL: postgresql://user:password@localhost/forensic_db

# JWT Configuration - REQUIRED FOR PRODUCTION
JWT_SECRET=your-super-secret-key-change-this-in-production-minimum-32-chars

# Authentication
USE_AD=False
AD_SERVER=ldap.company.com
AD_DOMAIN=COMPANY
AD_BASE_DN=cn=Users,dc=company,dc=com

# Server Configuration
SERVER_URL=
SERVER_HOST=0.0.0.0
SERVER_PORT=5000

# Redis Cache (optional)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# TLS/HTTPS Configuration (required for production)
TLS_ENABLED=True
TLS_CERT_PATH=/path/to/cert.pem
TLS_KEY_PATH=/path/to/key.pem

# Security Settings
PASSWORD_MIN_LENGTH=12
PASSWORD_REQUIRE_UPPERCASE=True
PASSWORD_REQUIRE_NUMBERS=True
PASSWORD_REQUIRE_SYMBOLS=True
LOGIN_ATTEMPT_LIMIT=5
LOGIN_LOCKOUT_DURATION=300

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/forensic_app.log

# CORS Configuration (for server mode)
CORS_ORIGINS=http://localhost:3000,https://app.company.com
