# =============================================================
# Python
# =============================================================
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
*.so
.python-version
.ipynb_checkpoints/

# =============================================================
# Virtual Environments
# =============================================================
.venv/
venv/
env/
ENV/
.env.local
env.bak/
venv.bak/

# =============================================================
# Build & Distribution (PyInstaller)
# Note: packaging/ (spec files) IS tracked — only outputs are excluded
# =============================================================
build/
dist/
*.spec.bak
*.egg-info/
.eggs/
*.egg

# =============================================================
# Environment / Secrets  (keep .env.example)
# =============================================================
.env
.env.*
!.env.example
!Forensic Server/.env.example
salt.bin
*.key
*.pem
*.p12
*.pfx

# =============================================================
# Databases
# =============================================================
*.db
*.sqlite
*.sqlite3
# Flask instance folder
instance/
# Forensic Server instance
Forensic Server/instance/

# =============================================================
# Logs
# =============================================================
logs/
*.log
Forensic Server/logs/

# =============================================================
# Test output / artifacts
# =============================================================
.pytest_cache/
.mypy_cache/
.ruff_cache/
.hypothesis/
.tox/
.nox/
pytest_output.txt
pytest_out2.txt
pytest_full.txt
pytest_full.log
pytest_run_output.txt
.pytest_app_output.txt
.pytest_last_run.txt
test_results.txt
htmlcov/
.coverage
.coverage.*
coverage.xml

# =============================================================
# Case data (user-generated, potentially sensitive)
# =============================================================
cases/*/
# Keep the cases/ directory itself
!cases/.gitkeep

# =============================================================
# IDE / Editor
# =============================================================
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.user
*.userossc
*.sln.docstates

# =============================================================
# OS
# =============================================================
.DS_Store
Thumbs.db
desktop.ini

# =============================================================
# Local caches / runtime artifacts
# =============================================================
*.cache
tmp/
temp/

# =============================================================
# Miscellaneous binaries / archives
# =============================================================
icon files.zip
*.zip
*.tar.gz

# =============================================================
# Docs archive (keep folder marker/readme, ignore archived content)
# =============================================================
docs/archive/*
!docs/archive/README.md
