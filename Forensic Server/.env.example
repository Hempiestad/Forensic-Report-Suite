# Required
JWT_SECRET=replace-with-at-least-32-characters

# Optional server runtime
SERVER_HOST=0.0.0.0
SERVER_PORT=5000
FLASK_ENV=development
FLASK_DEBUG=false

# TLS
TLS_ENABLED=true
TLS_CERT_PATH=
TLS_KEY_PATH=

# Database
DATABASE_URL=sqlite:///server.db

# Rate limiting + cache
RATE_LIMIT_ENABLED=true
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Discovery
DISCOVERY_SHARED_TOKEN=
DISCOVERY_SCAN_CIDRS=
DISCOVERY_SCAN_PORTS=5000,8080,8765
DISCOVERY_SCAN_MAX_HOSTS=96

# CORS
CORS_ORIGINS=http://localhost:5000,https://localhost:5000

# Metrics endpoint bearer token (optional)
METRICS_TOKEN=

# SMTP for /feature_requests (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_FROM_EMAIL=
FEATURE_REQUEST_TO_EMAIL=
